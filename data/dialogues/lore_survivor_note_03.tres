[gd_resource type="Resource" script_class="EventData" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/resources/event_data.gd" id="1"]

[resource]
script = ExtResource("1")
id = "lore_survivor_note_03"
event_type = 0
description = "【手写笔记 - 撕下的笔记本页面】

钉在电线杆上，用钢笔工整书写：

'致后来者：

我叫周明远。崩溃前是城西中学的数学老师。

崩溃发生时我正在上课。我的32个学生里有15个男生。我亲眼看着他们在课桌前变异。有些孩子在变异的过程中还在叫'周老师救我'。

我什么都做不了。

女生们跟着我撤到了地下室。我们坚持了九天。第十天，救援来了。

现在我在避难所教孩子们数学。黑板换成了墙壁，粉笔换成了木炭。没有课本了，但我还记得所有的公式。

这大概是我唯一还能做的事。

数学不会变异。1+1永远等于2。在这个什么都在崩溃的世界里，这让我安心。'"
san_change = 2.0
low_san_description = "笔记的背面有一道数学题，反复写了上百遍：'1+1=？'答案每次都不一样。2、3、0、-1、∞、骷髅符号。最后一行的答案是一个你看不懂的符号，但它让你的视网膜剧痛。"
critical_san_description = "周明远就站在你面前。他还在拿着粉笔。但他写在空气里的公式正在改变现实——数字从方程式中掉出来，变成了虫子。1+1=死亡。他微笑着对你说：'来，回答这道题。'"
